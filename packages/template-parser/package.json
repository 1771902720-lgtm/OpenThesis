{
  "name": "@openthesis/template-parser",
  "version": "0.2.0",
  "description": "Parse any .docx template into structured JSON style DSL — resolves style inheritance, extracts fonts, sizes, margins, alignment",
  "keywords": ["docx", "template", "parser", "word", "office", "styles", "typescript", "openxml"],
  "repository": { "type": "git", "url": "https://github.com/1771902720-lgtm/OpenThesis.git", "directory": "packages/template-parser" },
  "homepage": "https://github.com/1771902720-lgtm/OpenThesis#readme",
  "license": "MIT",
  "author": "OpenThesis Contributors",
  "publishConfig": { "access": "public" },
  "files": ["dist", "src", "README.md"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
