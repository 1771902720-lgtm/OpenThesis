{
  "name": "@openthesis/template-parser",
  "version": "0.1.0",
  "description": "Parse any university .docx thesis template into a structured JSON style DSL",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
