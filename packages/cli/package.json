{
  "name": "@openthesis/cli",
  "version": "0.2.0",
  "description": "OpenThesis CLI — parse .docx templates, build thesis/journal/official documents from JSON",
  "keywords": ["docx", "cli", "thesis", "journal", "official-document", "template", "word", "document-generator"],
  "repository": { "type": "git", "url": "https://github.com/1771902720-lgtm/OpenThesis.git", "directory": "packages/cli" },
  "homepage": "https://github.com/1771902720-lgtm/OpenThesis#readme",
  "license": "MIT",
