{
  "name": "@openthesis/docx-renderer",
  "version": "0.1.0",
  "description": "Template-driven DOCX renderer — converts ThesisDocument + ThesisTemplate → submission-ready .docx",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "echo 'Tests not yet configured'"
  },
  "dependencies": {
    "@openthesis/document-schema": "workspace:*",
    "docx": "^9.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.5"
  }
}
